---
interface Props {
  image?: string;
  caption?: string;
  data: Array<{ label: string; value: string }>;
}

const imageUrls = import.meta.glob('../assets/images/**/*.{avif,gif,jpeg,jpg,png,svg,webp}', {
  eager: true,
  import: 'default',
  query: '?url',
});

function resolveImagePath(image?: string) {
  if (!image) return undefined;
  if (image.startsWith('http://') || image.startsWith('https://')) return image;
  if (image.startsWith('/zwierzyncopedia/') || image.startsWith('/assets/')) return image;

  const normalizedImage = image.startsWith('/') ? image.slice(1) : image;
  return imageUrls[`../assets/images/${normalizedImage}`] ?? image;
}

const { image, caption, data } = Astro.props;
const imageSrc = resolveImagePath(image);
---

<aside class="zw-infobox">
  {imageSrc && (
    <figure class="zw-infobox__figure">
      <img src={imageSrc} alt={caption || ''} />
      {caption && <figcaption>{caption}</figcaption>}
    </figure>
  )}
  <dl class="zw-infobox__data">
    {data.map(({ label, value }) => (
      <>
        <dt>{label}</dt>
        <dd set:html={value} />
      </>
    ))}
  </dl>
</aside>
